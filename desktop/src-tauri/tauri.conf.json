{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Open Claude Code",
  "version": "0.1.0",
  "identifier": "com.opencode.code",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devUrl": null,
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Open Claude Code",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
